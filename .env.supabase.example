# Configuration Supabase pour le déploiement
# Copiez ce fichier en .env.supabase et remplacez les valeurs

# Project Reference (trouvez-le dans l'URL Supabase: https://app.supabase.com/project/<PROJECT_REF>)
SUPABASE_PROJECT_REF=your-project-ref-here

# Clé API Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx

# Email d'expédition
EMAIL_FROM=noreply@aphs-international.com
# Pour tester avec Resend: onboarding@resend.dev

# URL de l'application (pour les liens dans les emails)
APP_URL=https://votre-app.com
# Pour le développement: http://localhost:5173
